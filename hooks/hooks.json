{
  "description": "duy-workflow plugin hooks - format-on-save for code quality",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/format-on-save.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
